{
  "name": "opennote",
  "productName": "OpenNote",
  "description": "OpenNote - a local-first, data-sovereign Notion-style workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run test && npm run build",
    "start": "npm run build && electron .",
    "sync-server": "vite build --ssr server/main.ts --outDir dist-server && node dist-server/main.js"
  },
  "dependencies": {
    "@blocknote/core": "^0.17.1",
    "@blocknote/mantine": "^0.17.1",
    "@blocknote/react": "^0.17.1",
    "@electric-sql/pglite": "^0.2.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
